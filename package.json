{
  "name": "cloudcore-cms",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "dev:local": "wrangler dev --local --persist-to=.wrangler/state",
    "build": "wrangler deploy --dry-run --outdir=dist",
    "deploy": "wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply cloudcore-db --local",
    "db:migrate:prod": "wrangler d1 migrations apply cloudcore-db --remote",
    "db:studio": "drizzle-kit studio",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "drizzle-kit": "^1.0.0-beta.20",
    "typescript": "^5.6.0",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.0"
  }
}
